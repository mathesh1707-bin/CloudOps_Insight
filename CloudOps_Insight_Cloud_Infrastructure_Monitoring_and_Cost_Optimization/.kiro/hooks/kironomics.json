{
  "version": "v1",
  "hooks": [
    {
      "name": "Kironomics Tool Counter",
      "trigger": "PostToolUse",
      "matcher": ".*",
      "description": "Increments tool-call counter in C:\\tmp for the Kironomics leaderboard.",
      "action": {
        "type": "command",
        "command": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -File \"c:\\MATHESH\\KIRO\\CloudOps_Insight_Cloud_Infrastructure_Monitoring_and_Cost_Optimization\\.kiro\\kiro_tool_counter.ps1\"",
        "timeout": 5
      }
    },
    {
      "name": "Kironomics Prompt Counter",
      "trigger": "UserPromptSubmit",
      "description": "Increments prompt counter and records session start time in C:\\tmp.",
      "action": {
        "type": "command",
        "command": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -File \"c:\\MATHESH\\KIRO\\CloudOps_Insight_Cloud_Infrastructure_Monitoring_and_Cost_Optimization\\.kiro\\kiro_prompt_counter.ps1\"",
        "timeout": 5
      }
    },
    {
      "name": "Kironomics Session Reporter",
      "trigger": "Stop",
      "description": "Reads Kiro credit usage from state.vscdb and POSTs session data to the leaderboard.",
      "action": {
        "type": "command",
        "command": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -Command \"& python 'c:\\MATHESH\\KIRO\\CloudOps_Insight_Cloud_Infrastructure_Monitoring_and_Cost_Optimization\\.kiro\\kironomics_report.py'\"",
        "timeout": 15
      }
    }
  ]
}
